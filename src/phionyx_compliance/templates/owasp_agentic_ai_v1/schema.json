{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OWASPAgenticAIReportInputs",
  "description": "JSON Schema for the OWASP Agentic AI Threats v1.0 template inputs.",
  "type": "object",
  "required": [
    "provider_name", "system_identifier", "agent_topology",
    "trace_id", "window_start_iso", "window_end_iso",
    "envelope_count", "chain_valid", "chain_valid_label",
    "t1_memory_status", "t2_tool_misuse_status", "t3_privilege_status",
    "t4_resource_status", "t5_cascading_status", "t6_intent_breaking_status",
    "t7_misaligned_status", "t8_repudiation_status", "t9_spoofing_status",
    "t10_hitl_status",
    "tool_call_count", "claim_count",
    "verdict_distribution", "verdict_distribution_table",
    "distinct_descriptor_count", "descriptor_change_count", "anomaly_count",
    "descriptor_approval_workflow", "capability_profile_policy",
    "hitl_invocation_policy", "rate_limit_controls",
    "signing_key_id", "chain_integrity_summary", "human_oversight_summary",
    "anomaly_followup_instruction",
    "generated_at_iso", "template_version", "reproduction_command",
    "disclaimer_head", "disclaimer_tail"
  ],
  "properties": {
    "provider_name":              { "type": "string", "description": "[OPERATOR-SUPPLIED]" },
    "system_identifier":          { "type": "string", "description": "[OPERATOR-SUPPLIED]" },
    "agent_topology":             { "type": "string", "description": "[OPERATOR-SUPPLIED] single-agent / multi-agent supervisor / agent + tool calls / etc." },
    "trace_id":                   { "type": "string", "pattern": "^trace-[0-9a-f]{8,32}$" },
    "window_start_iso":           { "type": "string" },
    "window_end_iso":             { "type": "string" },
    "envelope_count":             { "type": "integer", "minimum": 0 },
    "chain_valid":                { "type": "boolean" },
    "chain_valid_label":          { "type": "string" },
    "t1_memory_status":           { "type": "string", "description": "[DERIVED] T1 coverage status sentence." },
    "t2_tool_misuse_status":      { "type": "string", "description": "[DERIVED]" },
    "t3_privilege_status":        { "type": "string", "description": "[DERIVED]" },
    "t4_resource_status":         { "type": "string", "description": "[DERIVED]" },
    "t5_cascading_status":        { "type": "string", "description": "[DERIVED]" },
    "t6_intent_breaking_status":  { "type": "string", "description": "[DERIVED]" },
    "t7_misaligned_status":       { "type": "string", "description": "[DERIVED]" },
    "t8_repudiation_status":      { "type": "string", "description": "[DERIVED]" },
    "t9_spoofing_status":         { "type": "string", "description": "[DERIVED]" },
    "t10_hitl_status":            { "type": "string", "description": "[DERIVED]" },
    "tool_call_count":            { "type": "integer", "minimum": 0 },
    "claim_count":                { "type": "integer", "minimum": 0 },
    "verdict_distribution":       { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "verdict_distribution_table": { "type": "string" },
    "distinct_descriptor_count":  { "type": "integer", "minimum": 0 },
    "descriptor_change_count":    { "type": "integer", "minimum": 0 },
    "anomaly_count":              { "type": "integer", "minimum": 0 },
    "descriptor_approval_workflow": { "type": "string", "description": "[OPERATOR-SUPPLIED] T2 mitigation." },
    "capability_profile_policy":    { "type": "string", "description": "[OPERATOR-SUPPLIED] T3 mitigation." },
    "hitl_invocation_policy":       { "type": "string", "description": "[OPERATOR-SUPPLIED] T10 control." },
    "rate_limit_controls":          { "type": "string", "description": "[OPERATOR-SUPPLIED] T4 mitigation." },
    "signing_key_id":               { "type": "string" },
    "chain_integrity_summary":      { "type": "string" },
    "human_oversight_summary":      { "type": "string" },
    "anomaly_followup_instruction": { "type": "string", "description": "[OPERATOR-SUPPLIED]" },
    "generated_at_iso":             { "type": "string" },
    "template_version":             { "type": "string" },
    "reproduction_command":         { "type": "string" },
    "disclaimer_head":              { "type": "string" },
    "disclaimer_tail":              { "type": "string" }
  }
}
