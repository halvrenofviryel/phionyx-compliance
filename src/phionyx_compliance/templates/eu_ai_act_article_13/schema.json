{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EUAIActArticle13ReportInputs",
  "description": "Pydantic-derived JSON Schema for inputs the EU AI Act Article 13 template consumes. Operator-supplied fields are marked in field descriptions.",
  "type": "object",
  "required": [
    "provider_name", "system_identifier", "trace_id",
    "window_start_iso", "window_end_iso", "envelope_count",
    "chain_valid", "chain_valid_label", "verification_command",
    "intended_purpose", "declared_limitations", "out_of_scope_uses",
    "tool_call_count", "claim_count", "verdict_distribution",
    "verdict_distribution_table", "distinct_descriptor_count",
    "descriptor_change_count", "anomaly_count", "signing_key_id",
    "chain_integrity_summary", "human_oversight_summary",
    "key_storage_location", "key_storage_mode",
    "key_rotation_event_count", "key_revocation_referenced_count",
    "worm_storage_status", "anomaly_followup_instruction",
    "generated_at_iso", "template_version", "reproduction_command",
    "disclaimer_head", "disclaimer_tail"
  ],
  "properties": {
    "provider_name": { "type": "string", "description": "[OPERATOR-SUPPLIED] Provider legal name per Article 13(1)." },
    "system_identifier": { "type": "string", "description": "[OPERATOR-SUPPLIED] Provider's identifier for the system." },
    "trace_id": { "type": "string", "pattern": "^trace-[0-9a-f]{8,32}$", "description": "[CHAIN-DERIVED] Trace identifier under assessment." },
    "window_start_iso": { "type": "string", "description": "[CHAIN-DERIVED] ISO-8601 timestamp of the first envelope." },
    "window_end_iso": { "type": "string", "description": "[CHAIN-DERIVED] ISO-8601 timestamp of the last envelope." },
    "envelope_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] Total envelopes assessed." },
    "chain_valid": { "type": "boolean", "description": "[CHAIN-DERIVED] Whether the chain validates." },
    "chain_valid_label": { "type": "string", "description": "[DERIVED] Human-readable chain validity." },
    "verification_command": { "type": "string", "description": "[DERIVED] One-line shell command that re-verifies." },
    "intended_purpose": { "type": "string", "description": "[OPERATOR-SUPPLIED] Declared intended purpose per Article 13(1)." },
    "declared_limitations": { "type": "string", "description": "[OPERATOR-SUPPLIED] Declared limitations + foreseeable misuse." },
    "out_of_scope_uses": { "type": "string", "description": "[OPERATOR-SUPPLIED] Explicitly out-of-scope use cases." },
    "tool_call_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] Tool-call envelopes in window." },
    "claim_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] Agent self-claim envelopes." },
    "verdict_distribution": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "description": "[CHAIN-DERIVED] Count per verdict (pass/reject/regenerate/rewrite/n_a)."
    },
    "verdict_distribution_table": { "type": "string", "description": "[DERIVED] Markdown table of verdicts." },
    "distinct_descriptor_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] Distinct tool_descriptor_hash values." },
    "descriptor_change_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] descriptor_change_detected=true count." },
    "anomaly_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] anomaly_flag=true count." },
    "signing_key_id": { "type": "string", "description": "[CHAIN-DERIVED] First envelope's integrity.key_id or '<varies>'." },
    "chain_integrity_summary": { "type": "string", "description": "[DERIVED] One-paragraph chain verification summary." },
    "human_oversight_summary": { "type": "string", "description": "[DERIVED] HITL invocation summary." },
    "key_storage_location": { "type": "string", "description": "[OPERATOR-SUPPLIED] Where the signing key lives." },
    "key_storage_mode": { "type": "string", "description": "[OPERATOR-SUPPLIED] Mode / KMS backend identifier." },
    "key_rotation_event_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] Key rotation envelopes in window (v0.6.0+)." },
    "key_revocation_referenced_count": { "type": "integer", "minimum": 0, "description": "[CHAIN-DERIVED] Envelopes whose signing key is now revoked." },
    "worm_storage_status": { "type": "string", "description": "[OPERATOR-SUPPLIED] WORM adapter status." },
    "anomaly_followup_instruction": { "type": "string", "description": "[OPERATOR-SUPPLIED] How anomaly envelopes are triaged." },
    "generated_at_iso": { "type": "string", "description": "[DERIVED] Report generation timestamp." },
    "template_version": { "type": "string", "description": "[DERIVED] Template semver." },
    "reproduction_command": { "type": "string", "description": "[DERIVED] One-line shell to regenerate." },
    "disclaimer_head": { "type": "string", "description": "[CANONICAL] Head disclaimer." },
    "disclaimer_tail": { "type": "string", "description": "[CANONICAL] Tail disclaimer." }
  }
}
