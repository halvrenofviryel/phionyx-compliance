{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ISO42001ReportInputs",
  "description": "JSON Schema for the ISO/IEC 42001:2023 template inputs.",
  "type": "object",
  "required": [
    "aims_organisation", "system_identifier", "life_cycle_stage",
    "trace_id", "window_start_iso", "window_end_iso",
    "envelope_count", "chain_valid", "chain_valid_label",
    "ai_policy_statement", "aims_objectives", "risk_acceptance_criteria",
    "resources_allocated", "competence_assurance",
    "tool_call_count", "claim_count",
    "verdict_distribution", "verdict_distribution_table",
    "distinct_descriptor_count", "descriptor_change_count", "anomaly_count",
    "operational_monitoring_procedures",
    "user_facing_documentation", "transparency_artefacts_published",
    "signing_key_id", "chain_integrity_summary", "human_oversight_summary",
    "anomaly_followup_instruction",
    "generated_at_iso", "template_version", "reproduction_command",
    "disclaimer_head", "disclaimer_tail"
  ],
  "properties": {
    "aims_organisation":                  { "type": "string", "description": "[OPERATOR-SUPPLIED] Organisation that operates the AIMS." },
    "system_identifier":                  { "type": "string", "description": "[OPERATOR-SUPPLIED]" },
    "life_cycle_stage":                   { "type": "string", "description": "[OPERATOR-SUPPLIED] A.6 stage: design / development / verification / deployment / operation / retirement." },
    "trace_id":                           { "type": "string", "pattern": "^trace-[0-9a-f]{8,32}$" },
    "window_start_iso":                   { "type": "string" },
    "window_end_iso":                     { "type": "string" },
    "envelope_count":                     { "type": "integer", "minimum": 0 },
    "chain_valid":                        { "type": "boolean" },
    "chain_valid_label":                  { "type": "string" },
    "ai_policy_statement":                { "type": "string", "description": "[OPERATOR-SUPPLIED] Clause 5.2 — top-management-approved AI policy." },
    "aims_objectives":                    { "type": "string", "description": "[OPERATOR-SUPPLIED] Clause 6.2 — measurable objectives for the window." },
    "risk_acceptance_criteria":           { "type": "string", "description": "[OPERATOR-SUPPLIED] Risk acceptance posture." },
    "resources_allocated":                { "type": "string", "description": "[OPERATOR-SUPPLIED] A.4 — resources for AI operations." },
    "competence_assurance":               { "type": "string", "description": "[OPERATOR-SUPPLIED] A.4 — personnel competence assurance." },
    "tool_call_count":                    { "type": "integer", "minimum": 0 },
    "claim_count":                        { "type": "integer", "minimum": 0 },
    "verdict_distribution":               { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "verdict_distribution_table":         { "type": "string" },
    "distinct_descriptor_count":          { "type": "integer", "minimum": 0 },
    "descriptor_change_count":            { "type": "integer", "minimum": 0 },
    "anomaly_count":                      { "type": "integer", "minimum": 0 },
    "operational_monitoring_procedures":  { "type": "string", "description": "[OPERATOR-SUPPLIED] A.6.2.9 — operational monitoring." },
    "user_facing_documentation":          { "type": "string", "description": "[OPERATOR-SUPPLIED] A.8 — interested-parties information." },
    "transparency_artefacts_published":   { "type": "string", "description": "[OPERATOR-SUPPLIED] A.8 — published transparency artefacts." },
    "signing_key_id":                     { "type": "string" },
    "chain_integrity_summary":            { "type": "string" },
    "human_oversight_summary":            { "type": "string" },
    "anomaly_followup_instruction":       { "type": "string", "description": "[OPERATOR-SUPPLIED]" },
    "generated_at_iso":                   { "type": "string" },
    "template_version":                   { "type": "string" },
    "reproduction_command":               { "type": "string" },
    "disclaimer_head":                    { "type": "string" },
    "disclaimer_tail":                    { "type": "string" }
  }
}
