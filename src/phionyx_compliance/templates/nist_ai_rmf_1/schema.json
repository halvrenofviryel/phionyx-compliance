{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NISTAIRMFReportInputs",
  "description": "JSON Schema for inputs the NIST AI RMF 1.0 template consumes.",
  "type": "object",
  "required": [
    "provider_name", "system_identifier", "ai_use_case_category",
    "trace_id", "window_start_iso", "window_end_iso", "envelope_count",
    "chain_valid", "chain_valid_label",
    "governance_policy_summary", "roles_and_accountability", "risk_tolerance_statement",
    "intended_context", "ai_capabilities_scope", "identified_risks",
    "tool_call_count", "claim_count", "verdict_distribution", "verdict_distribution_table",
    "distinct_descriptor_count", "descriptor_change_count", "anomaly_count",
    "out_of_chain_metrics",
    "incident_response_procedure", "recovery_measures", "stakeholder_communication",
    "signing_key_id", "chain_integrity_summary", "human_oversight_summary",
    "anomaly_followup_instruction",
    "generated_at_iso", "template_version", "reproduction_command",
    "disclaimer_head", "disclaimer_tail"
  ],
  "properties": {
    "provider_name":            { "type": "string" },
    "system_identifier":        { "type": "string" },
    "ai_use_case_category":     { "type": "string", "description": "[OPERATOR-SUPPLIED] NIST AI use-case category, e.g. customer service, decision support, content moderation." },
    "trace_id":                 { "type": "string", "pattern": "^trace-[0-9a-f]{8,32}$" },
    "window_start_iso":         { "type": "string" },
    "window_end_iso":           { "type": "string" },
    "envelope_count":           { "type": "integer", "minimum": 0 },
    "chain_valid":              { "type": "boolean" },
    "chain_valid_label":        { "type": "string" },
    "governance_policy_summary":   { "type": "string", "description": "[OPERATOR-SUPPLIED] Summary of the operator's GOVERN-function policy posture." },
    "roles_and_accountability":   { "type": "string", "description": "[OPERATOR-SUPPLIED] Who owns AI risk decisions in the operator org." },
    "risk_tolerance_statement":   { "type": "string", "description": "[OPERATOR-SUPPLIED] Declared risk tolerance / acceptance criteria." },
    "intended_context":            { "type": "string", "description": "[OPERATOR-SUPPLIED] MAP 1.x — intended context of use." },
    "ai_capabilities_scope":       { "type": "string", "description": "[OPERATOR-SUPPLIED] MAP 2.x — declared capabilities & limitations." },
    "identified_risks":            { "type": "string", "description": "[OPERATOR-SUPPLIED] MAP 5.x — risks identified by the operator." },
    "tool_call_count":             { "type": "integer", "minimum": 0 },
    "claim_count":                 { "type": "integer", "minimum": 0 },
    "verdict_distribution":        { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
    "verdict_distribution_table":  { "type": "string" },
    "distinct_descriptor_count":   { "type": "integer", "minimum": 0 },
    "descriptor_change_count":     { "type": "integer", "minimum": 0 },
    "anomaly_count":               { "type": "integer", "minimum": 0 },
    "out_of_chain_metrics":        { "type": "string", "description": "[OPERATOR-SUPPLIED] MEASURE-relevant metrics tracked outside the chain (latency, cost, user-reported errors, etc.)." },
    "incident_response_procedure": { "type": "string", "description": "[OPERATOR-SUPPLIED] MANAGE 4.x — incident response posture." },
    "recovery_measures":           { "type": "string", "description": "[OPERATOR-SUPPLIED] MANAGE 4.3 — recovery / rollback procedures." },
    "stakeholder_communication":   { "type": "string", "description": "[OPERATOR-SUPPLIED] MANAGE 4.x — who is notified, how, when." },
    "signing_key_id":              { "type": "string" },
    "chain_integrity_summary":     { "type": "string" },
    "human_oversight_summary":     { "type": "string" },
    "anomaly_followup_instruction": { "type": "string", "description": "[OPERATOR-SUPPLIED]" },
    "generated_at_iso":            { "type": "string" },
    "template_version":            { "type": "string" },
    "reproduction_command":        { "type": "string" },
    "disclaimer_head":             { "type": "string" },
    "disclaimer_tail":             { "type": "string" }
  }
}
